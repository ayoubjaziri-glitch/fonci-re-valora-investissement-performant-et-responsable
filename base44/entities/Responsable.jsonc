{
  "name": "Responsable",
  "type": "object",
  "properties": {
    "nom": {
      "type": "string",
      "description": "Nom complet du responsable"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email du responsable"
    },
    "actif": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "nom",
    "email"
  ]
}