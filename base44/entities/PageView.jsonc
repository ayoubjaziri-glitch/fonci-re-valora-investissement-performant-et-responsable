{
  "name": "PageView",
  "type": "object",
  "properties": {
    "page": {
      "type": "string",
      "description": "Nom de la page visit\u00e9e"
    },
    "path": {
      "type": "string",
      "description": "Chemin URL"
    },
    "session_id": {
      "type": "string",
      "description": "ID de session anonyme"
    },
    "user_agent": {
      "type": "string",
      "description": "User agent du navigateur"
    },
    "referrer": {
      "type": "string",
      "description": "URL compl\u00e8te de provenance"
    },
    "search_keywords": {
      "type": "string",
      "description": "Mots-cl\u00e9s tap\u00e9s dans Google/Bing pour arriver sur le site"
    },
    "country": {
      "type": "string",
      "description": "Pays du visiteur"
    },
    "city": {
      "type": "string",
      "description": "Ville du visiteur"
    },
    "lat": {
      "type": "number",
      "description": "Latitude"
    },
    "lng": {
      "type": "number",
      "description": "Longitude"
    },
    "ip": {
      "type": "string",
      "description": "IP (partielle)"
    }
  },
  "required": [
    "page",
    "path"
  ]
}